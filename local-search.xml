e class="hljs c++"><span class="hljs-comment">// 加法 版本</span><br><span class="hljs-type">int</span> arr[<span class="hljs-number">100005</span>];<br><br><span class="hljs-keyword">struct</span> <span class="hljs-title class_">node</span>&#123;<br>    <span class="hljs-type">int</span> l,r;<br>    <span class="hljs-type">int</span> sum=<span class="hljs-number">0</span>,lz=<span class="hljs-number">0</span>;<br>&#125; tree[<span class="hljs-number">400005</span>];<br><br><span class="hljs-function"><span class="hljs-type">void</span> <span class="hljs-title">build</span><span class="hljs-params">(<span class="hljs-type">int</span> l, <span class="hljs-type">int</span> r, <span class="hljs-type">int</span> i=<span class="hljs-number">1</span>)</span></span>&#123;<br>    tree[i].l = l; tree[i].r = r;<br>    <span class="hljs-keyword">if</span>(r==l)&#123;<br>        tree[i].sum = arr[l]; <span class="hljs-keyword">return</span>;<br>    &#125;<br>    <span class="hljs-type">int</span> mid = (l+r)&gt;&gt;<span class="hljs-number">1</span>;<br>    <span class="hljs-built_in">build</span>(l,mid,<span class="hljs-number">2</span>*i);<br>    <span class="hljs-built_in">build</span>(mid<span class="hljs-number">+1</span>,r,<span class="hljs-number">2</span>*i<span class="hljs-number">+1</span>);<br>    tree[i].sum = tree[<span class="hljs-number">2</span>*i].sum + tree[<span class="hljs-number">2</span>*i<span class="hljs-number">+1</span>].sum;<br>&#125;<br><br><span class="hljs-function"><span class="hljs-type">void</span> <span class="hljs-title">pushdown</span><span class="hljs-params">(<span class="hljs-type">int</span> i)</span></span>&#123;<br>    <span class="hljs-keyword">if</span>(tree[i].l == tree[i].r) <span class="hljs-keyword">return</span>;<br>    <span class="hljs-keyword">if</span>(tree[i].lz!=<span class="hljs-number">0</span>)&#123;<br>        <span class="hljs-type">int</span> lz = tree[i].lz;<br>        tree[<span class="hljs-number">2</span>*i].lz += lz;